{
  "training": {
    "template": [
      {
        "role": "user",
        "content": [{ "type": "text", "text": "{{instruction}}" }]
      },
      {
        "role": "assistant",
        "content": [
          { "type": "text", "text": "{{caption}}" },
          { "type": "function", "name": "object_action_detect", "args": { "query": "{{instruction}}", "srcs": [] } }
        ]
      }
    ]
  },
  "inference": {
    "template": [
      {
        "role": "user",
        "content": [{ "type": "text", "text": "{{instruction}}" }]
      },
      {
        "role": "assistant",
        "content": [
          { "type": "function", "name": "object_action_detect", "args": { "query": "{{instruction}}", "srcs": [] } },
          { "type": "text", "text": "{{response}}" }
        ]
      }
    ]
  }
}